# Copy to .env and fill in values:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
# Base URL for the RAG API. Used by Streamlit chat, document pipeline, and voice.
BACKEND=http://localhost:8000

# HTTP timeout (seconds) for client requests to the backend.
CLIENT_REQUEST_TIMEOUT=600

# -----------------------------------------------------------------------------
# LLM provider
# -----------------------------------------------------------------------------
# Options: openai | anthropic | google | ollama | auto
# "auto" tries openai → anthropic → google → ollama until one succeeds.
LLM_PROVIDER=ollama

# Optional model override (provider default used if empty).
# Do NOT set this to the provider name (e.g. "ollama").
# openai:    gpt-4o
# anthropic: claude-3-5-sonnet-20240620
# google:    gemini-1.5-pro
# ollama:    llama3
DEFAULT_LLM_MODEL=

DEFAULT_LLM_TEMPERATURE=0.2

# -----------------------------------------------------------------------------
# API keys (set the key for your chosen LLM_PROVIDER)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Ollama (local, no API key required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_REQUEST_TIMEOUT=600

# -----------------------------------------------------------------------------
# RAG / chat defaults
# -----------------------------------------------------------------------------
DEFAULT_USE_RAG=true
DEFAULT_RAG_K=5

# Optional: restrict retrieval to a specific source label from the vector store.
DEFAULT_RAG_SOURCE_FILTER=

# -----------------------------------------------------------------------------
# Document ingestion pipeline
# -----------------------------------------------------------------------------
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=200
DEFAULT_VECTOR_SOURCE_LABEL=system-source

# -----------------------------------------------------------------------------
# Voice assistant (voice/main.py)
# -----------------------------------------------------------------------------
VOICE_RECORD_SECONDS=5
# tiny is fastest on CPU for MVP; use base/small for better accuracy
WHISPER_MODEL=tiny
TTS_VOICE=en-US-JennyNeural
# Slightly livelier / brighter delivery (edge-tts format: +8%, +4Hz)
TTS_RATE=+8%
TTS_PITCH=+4Hz

# Optional: faster Hugging Face model downloads
# HF_TOKEN=
